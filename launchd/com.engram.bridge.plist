<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
        "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Engram user-launchd manifest.

  Install:
    cp launchd/com.engram.bridge.plist ~/Library/LaunchAgents/
    # Edit the file to set absolute paths for ProgramArguments and WorkingDirectory.
    launchctl load ~/Library/LaunchAgents/com.engram.bridge.plist

  Uninstall:
    launchctl unload ~/Library/LaunchAgents/com.engram.bridge.plist
    rm ~/Library/LaunchAgents/com.engram.bridge.plist

  Logs:
    tail -f ~/.engram/logs/bridge.out.log
    tail -f ~/.engram/logs/bridge.err.log
-->
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.engram.bridge</string>

    <!-- EDIT: absolute path to `engram` entrypoint.
         Get it with: `which engram` after install.sh finishes. -->
    <key>ProgramArguments</key>
    <array>
        <string>/REPLACE/WITH/ABSOLUTE/PATH/TO/engram</string>
        <string>run</string>
    </array>

    <!-- EDIT: absolute path to the repo checkout. -->
    <key>WorkingDirectory</key>
    <string>/REPLACE/WITH/ABSOLUTE/PATH/TO/engram-repo</string>

    <key>EnvironmentVariables</key>
    <dict>
        <!-- The setup wizard writes everything to ~/.engram/config.yaml,
             so launchd doesn't need to know the tokens. But the PATH
             is important — the SDK spawns `claude` as a subprocess. -->
        <key>PATH</key>
        <string>/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin:/opt/homebrew/bin</string>
        <key>LANG</key>
        <string>en_US.UTF-8</string>
    </dict>

    <key>RunAtLoad</key>
    <true/>

    <key>KeepAlive</key>
    <dict>
        <key>SuccessfulExit</key>
        <false/>
        <key>Crashed</key>
        <true/>
    </dict>

    <!-- Avoid tight crash loops: wait 30s before restart. -->
    <key>ThrottleInterval</key>
    <integer>30</integer>

    <key>SoftResourceLimits</key>
    <dict>
        <key>NumberOfFiles</key>
        <integer>4096</integer>
    </dict>

    <key>StandardOutPath</key>
    <string>/tmp/engram.bridge.out.log</string>

    <key>StandardErrorPath</key>
    <string>/tmp/engram.bridge.err.log</string>

    <!-- Be a polite user agent: low I/O priority, normal CPU. -->
    <key>ProcessType</key>
    <string>Background</string>
</dict>
</plist>
