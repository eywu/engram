# === Engram runtime artifacts ===
# Per-channel state directories live in ~/.engram/, NOT in the repo.
# But if someone sets ENGRAM_STATE_DIR=./state/ during local testing,
# don't commit it:
state/
logs/
*.log
*.log.*
routing-state.json
message-queue.json

# === Internal planning / working docs ===
# Keep long-form planning, retros, and internal specs OUT of the public repo.
# The canonical location for those is ~/.openclaw/workspace/memory/engram-planning/
# If anyone drops working notes into the repo for convenience, gitignore them:
internal/
planning/
retro/
*.internal.md
NOTES.md
SCRATCH.md

# === M0 / verification scratch (never committed) ===
verify-scratch/
m0-*.md

# === Test output ===
.pytest_cache/
test-results/
coverage.xml
